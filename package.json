{
  "name": "modular-backend",
  "version": "0.1.0",
  "description": "Modular Express backend with auth and user domains",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node prisma/seed.js",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.js\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "express",
    "prisma",
    "modular",
    "auth"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "6.19.2",
    "axios": "latest",
    "bcryptjs": "latest",
    "cors": "latest",
    "dotenv": "^17.3.1",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "joi": "latest",
    "jsonwebtoken": "latest",
    "pino": "latest",
    "pino-http": "^11.0.0",
    "pino-pretty": "latest",
    "prisma": "6.19.2"
  },
  "devDependencies": {
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-import": "latest",
    "eslint-plugin-node": "latest",
    "nodemon": "latest",
    "prettier": "latest"
  }
}
