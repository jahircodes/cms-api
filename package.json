{
  "name": "modular-backend",
  "version": "0.1.0",
  "description": "Modular Express backend with auth and user domains",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node prisma/seed.js",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.js\"",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ./prisma/schema.prisma"
  },
  "keywords": [
    "express",
    "prisma",
    "modular",
    "auth"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "latest",
    "bcryptjs": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "joi": "latest",
    "jsonwebtoken": "latest",
    "pino": "latest",
    "pino-http": "^11.0.0",
    "pino-pretty": "latest"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@prisma/config": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-import": "latest",
    "eslint-plugin-node": "latest",
    "nodemon": "latest",
    "prettier": "latest",
    "prisma": "^7.4.2"
  }
}
